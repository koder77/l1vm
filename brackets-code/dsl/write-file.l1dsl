// write-file.l1dsl
parser: "write file, file write, binary write"
match: has_write_file
include: intr-func.l1h
var: const-int64 zero 1 0
var: int64 fh 1 -1
var: int64 val 1 42
var: const-string fname 10 "data.bin"
var: const-string mode 4 "wb"
desc: "Write an int64 value to a binary file"

code:
    (fname mode :fopen !)
    (fh stpop)
    (val fh :fwrite_int64 !)
    (fh :fclose !)
