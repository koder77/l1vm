// write-file.l1dsl
parser: "write file, file write, binary write"
match: has_write_file
include: intr-func.l1h
desc: "Write an int64 value to a binary file"

code:
    (set const-int64 1 zero 0)
    (set int64 1 fh -1)
    (set int64 1 val 42)
    (set string s fname "data.bin")
    (set string s mode "wb")
    (fname mode :fopen !)
    (fh stpop)
    (val fh :fwrite_int64 !)
    (fh :fclose !)
