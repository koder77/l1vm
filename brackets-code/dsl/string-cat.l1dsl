// string-cat.l1dsl
parser: "concatenate strings"
include: intr-func.l1h
include-post: string.l1h
desc: "String concatenation demo"
code:
    (set const-int64 1 zero 0)
    (set int64 1 strmod 0)
    (set string 8 a "Hello ")
    (set string 10 b "Brackets")
    (set string 256 result "")
    (strmod :string_init !)
    (a :print_s !)
    (:print_n !)
    (result a :string_copy !)
    (result b :string_cat !)
    (result :print_s !)
    (:print_n !)
