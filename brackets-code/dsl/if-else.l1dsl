// if-else.l1dsl
parser: "if else"
include: intr-func.l1h
desc: "If-else conditionals"
code:
    (set const-int64 1 zero 0)
    (set int64 1 x 7)
    (set int64 1 y 10)
    (set int64 1 f 0)
    (set const-string 6 less_str "x < y")
    (set const-string 7 more_str "x >= y")
    (((x y <) f :=) f if)
        (less_str :print_s !)
        (:print_n !)
    (endif)
    (((x y >=) f :=) f if)
        (more_str :print_s !)
        (:print_n !)
    (endif)
