// for-loop-countdown.l1dsl
parser: "countdown, count down, backwards, decrement"
match: has_countdown_from
token: int64 start
include: intr-func.l1h
desc: "Count down from start to zero and print each number"

code:
    (set const-int64 1 zero 0)
    (set const-int64 1 one 1)
    (set int64 1 i 0)
    (set int64 1 f 0)
    (start i :=)
    (do)
        (i :print_i !)
        (:print_n !)
        (i - one i :=)
    (((i zero >) f :=) f while)
    (zero :print_i !)
    (:print_n !)
