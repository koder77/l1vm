// factorial.l1dsl
parser: "factorial, calculate factorial"
match: has_factorial
token: int64 n
result: int64 fact
include: intr-func.l1h
desc: "Calculate the factorial of n using iterative multiplication"

code:
    (set const-int64 1 zero 0)
    (set const-int64 1 one 1)
    (set int64 1 i 1)
    (set int64 1 f 0)
    (one fact :=)
    (for-loop)
    (((i n <=) f :=) f for)
        (fact * i fact :=)
        (i + one i :=)
    (next)
    (fact :print_i !)
    (:print_n !)
