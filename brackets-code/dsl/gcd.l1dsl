// gcd.l1dsl
parser: "gcd, greatest common divisor, ggt"
match: has_gcd
token: int64 a, int64 b
result: int64 result
include: intr-func.l1h
desc: "Calculate the greatest common divisor of two numbers using Euclidean algorithm"

code:
    (set const-int64 1 zero 0)
    (set int64 1 f 0)
    (set int64 1 temp 0)
    (do)
        (a % b temp :=)
        (b a :=)
        (temp b :=)
    (((b zero >) f :=) f while)
    (a :print_i !)
    (:print_n !)
