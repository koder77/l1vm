// gcd.l1dsl
parser: "gcd, greatest common divisor, ggt"
match: has_gcd
token: int64 a, int64 b
result: int64 result
include: intr-func.l1h
var: const-int64 zero 1 0
var: int64 f 1 0
var: int64 temp 1 0
desc: "Calculate the greatest common divisor of two numbers using Euclidean algorithm"

code:
    (do)
        (a % b temp :=)
        (b a :=)
        (temp b :=)
    (((b zero >) f :=) f while)
    (a :print_i !)
    (:print_n !)
