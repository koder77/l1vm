// bool-demo.l1dsl
parser: "boolean variable"
include: intr-func.l1h
desc: "Boolean variable demo"
code:
    (set const-int64 1 zero 0)
    (set const-int64 1 one 1)
    (set int64 1 flag 1)
    (set int64 1 f 0)
    (set const-string 13 true_str "flag is true")
    (set const-string 14 false_str "flag is false")
    // boolean variable demo
    (((flag one ==) f :=) f if+)
        (true_str :print_s !)
    (else)
        (false_str :print_s !)
    (endif)
    (:print_n !)
