// double-power.l1dsl
parser: "double power, pow double, exponent double"
match: has_double_power
token: double base, double exp
result: double result
include: intr-func.l1h
desc: "Calculate power of double (using repeated multiplication)"

code:
    (set const-double 1 zero 0.0)
    (set const-double 1 one 1.0)
    (one result :=)
    (for-loop)
    (((i exp_i <) f :=) f for)
        (result *d base result :=)
        (i + one i :=)
    (next)
    (result :print_d !)
    (:print_n !)
