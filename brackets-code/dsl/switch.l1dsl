// switch.l1dsl
parser: "switch"
include: intr-func.l1h
desc: "Switch/case example"
code:
    (set const-int64 1 zero 0)
    (set int64 1 y 23)
    (set const-int64 1 c23 23)
    (set const-int64 1 c42 42)
    (set const-string 7 str23 "y = 23")
    (set const-string 7 str42 "y = 42")
    (switch)
    (y c23 ?)
        (str23 :print_s !)
        (:print_n !)
    (break)
    (y c42 ?)
        (str42 :print_s !)
        (:print_n !)
    (break)
    (switchend)
