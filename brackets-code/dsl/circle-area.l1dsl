// circle-area.l1dsl
parser: "circle area, area of circle"
match: has_circle_area
token: int64 radius
result: int64 area
include: intr-func.l1h
var: const-int64 zero 1 0
var: const-int64 three 1 3
var: const-int64 fourteen 1 14
var: int64 r2 1 0
desc: "Calculate the area of a circle (approximate using 3.14 for pi)"

code:
    (radius * radius r2 :=)
    (r2 * three area :=)
    (area * fourteen area :=)
    (area / hundred area :=)
    (area :print_i !)
    (:print_n !)
