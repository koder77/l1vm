// temp-convert.l1dsl
parser: "temperature convert, celsius fahrenheit, temp convert"
match: has_temp_convert
token: int64 celsius
result: int64 fahrenheit
include: intr-func.l1h
var: const-int64 zero 1 0
var: const-int64 nine 1 9
var: const-int64 five 1 5
var: const-int64 thirtytwo 1 32
var: int64 f 1 0
desc: "Convert Celsius to Fahrenheit"

code:
    (celsius * nine f :=)
    (f / five f :=)
    (f + thirtytwo fahrenheit :=)
    (fahrenheit :print_i !)
    (:print_n !)
