// power-template.l1dsl
parser: "power, exponentiation"
include: intr-func.l1h
desc: "Power/exponentiation function"

code:
    (set const-int64 1 zero 0)
    (set const-int64 1 one 1)
    (set int64 1 base 2)
    (set int64 1 exp 10)
    (set int64 1 ret 1)
    (set int64 1 i 0)
    (set int64 1 f 0)
    (zero i :=)
    (for-loop)
    (((i exp <) f :=) f for)
        (ret * base ret :=)
        (i + one i :=)
    (next)
    (ret :print_i !)
    (:print_n !)
    (zero :exit !)
