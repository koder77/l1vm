// function.l1dsl
parser: "function, define function, subroutine"
match: has_function
include: intr-func.l1h
include: vars.l1h
var: const-int64 zero 1 0
var: const-int64 one 1 1
var: int64 arg 1 0
var: int64 retval 1 0
var: int64 f 1 0
desc: "Define and call a function in Brackets"

code:
    // (myfunc func)
    //     #var ~ myfunc
    //     (set int64 1 arg~ 0)
    //     (arg~ stpop)
    //     (arg~ + one arg~ :=)
    //     (arg~ stpush)
    //     (return)
    // (funcend)
