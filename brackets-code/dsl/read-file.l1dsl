// read-file.l1dsl
parser: "read file, file read, binary read"
match: has_read_file
include: intr-func.l1h
desc: "Read an int64 value from a binary file"

code:
    (set const-int64 1 zero 0)
    (set int64 1 fh -1)
    (set int64 1 val 0)
    (set string s fname "data.bin")
    (set string s mode "rb")
    (fname mode :fopen !)
    (fh stpop)
    (fh val :fread_int64 !)
    (val :print_i !)
    (:print_n !)
    (fh :fclose !)
