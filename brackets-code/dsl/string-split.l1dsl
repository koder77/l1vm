// string-split.l1dsl
parser: "string split, split string, delimited string"
match: has_string_split
include: intr-func.l1h
var: const-int64 zero 1 0
var: const-string delim 3 "\",\""
var: const-string srcstr 21 "\"apple,banana,cherry\""
var: string result 256 "\"\""
var: int64 ret 1 0
desc: "Split a delimited string into parts"

code:
    (// string_split demo)
    (srcstr result delim :string_split !)
    (ret stpopi)
    (result :print_s !)
    (:print_n !)
    (zero :exit !)
