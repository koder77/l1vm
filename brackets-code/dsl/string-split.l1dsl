// string-split.l1dsl
parser: "string split, split string, delimited string"
match: has_string_split
include: intr-func.l1h
desc: "Split a delimited string into parts"

code:
    (set const-int64 1 zero 0)
    (set string s delim ",")
    (set string s srcstr "apple,banana,cherry")
    (set string 256 result "")
    (set int64 1 ret 0)
    (// string_split demo)
    (srcstr result delim :string_split !)
    (ret stpopi)
    (result :print_s !)
    (:print_n !)
    (zero :exit !)
