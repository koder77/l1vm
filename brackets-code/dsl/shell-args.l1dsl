// shell-args.l1dsl
parser: "keywords for matching"
match: has_shell_args
include: intr-func.l1h
desc: "command-line args demo"
code:
    (set const-int64 1 zero 0)
    (set const-int64 1 one 1)
    (set int64 1 argc 0)
    (set string 256 argstr 0)
    (set string s label "args: ")
    // command-line args demo
    (:argc !)
    (argc stpopi)
    (label :print_s !)
    (argc :print_i !)
    (:print_n !)
    (zero :exit !)
