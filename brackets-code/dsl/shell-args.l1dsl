// shell-args.l1dsl
parser: "keywords for matching"
match: has_shell_args
token: token type and name
result: result type and name
include: intr-func.l1h
var: const-int64 zero 1 0
var: const-int64 one 1 1
var: int64 argc 1 0
var: string argstr 256 0
var: const-string label 7 "args: "
desc: "command-line args demo"
code:
    // command-line args demo
    (:argc !)
    (argc stpopi)
    (label :print_s !)
    (argc :print_i !)
    (:print_n !)
    (zero :exit !)
