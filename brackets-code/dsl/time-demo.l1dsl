// time-demo.l1dsl
parser: "keywords for matching"
match: has_time
token: token type and name
result: result type and name
include: intr-func.l1h
desc: "time demo: get current timestamp"
code:
    (set const-int64 1 zero 0)
    (set int64 1 t 0)
    (set string s label "timestamp: ")
    (:time !)
    (t stpopi)
    (label :print_s !)
    (t :print_i !)
    (:print_n !)
    (zero :exit !)
