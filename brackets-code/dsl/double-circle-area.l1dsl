// double-circle-area.l1dsl
parser: "double circle area, area circle double"
match: has_double_circle_area
token: double radius
result: double area
include: intr-func.l1h
desc: "Calculate area of a circle using double precision"

code:
    (set const-double 1 zero 0.0)
    (set const-double 1 pi 3.14159)
    (radius *d radius r2 :=)
    (r2 *d pi area :=)
    (area :print_d !)
    (:print_n !)
