// hello-name.l1dsl
parser: "hello name"
include: intr-func.l1h
desc: "Ask name and greet"
code:
    (set const-int64 1 zero 0)
    (set const-int64 1 maxlen 256)
    (set string 256 name "")
    (set const-string 22 ask_str "What is your name? ")
    (set const-string 8 hello_str "Hello, ")
    (ask_str :print_s !)
    (maxlen name :input_s !)
    (hello_str :print_s !)
    (name :print_s !)
    (:print_n !)
