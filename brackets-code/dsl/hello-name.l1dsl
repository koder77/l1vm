// hello-name.l1dsl
parser: "hello name, greet, say hello"
match: has_hello_name
include: intr-func.l1h
include-post: string.l1h
desc: "Ask for a name, then print a greeting"

code:
    (set const-int64 1 zero 0)
    (set const-int64 1 maxlen 256)
    (set string 256 name "")
    (set string s greet "Hello, ")
    (set int64 0 strmod )
    (strmod :string_init !)
    (greet :print_s !)
    (maxlen name :input_s !)
    (name :print_s !)
    (:print_n !)
