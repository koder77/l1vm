// double-sqrt.l1dsl
parser: "double sqrt, square root double, sqrt double"
match: has_double_sqrt
token: double n
result: double root
include: intr-func.l1h
desc: "Calculate square root of a double"

code:
    (set const-double 1 zero 0.0)
    (n :sqrt_d root !)
    (root :print_d !)
    (:print_n !)
