// double-sqrt.l1dsl
parser: "double sqrt, square root double, sqrt double"
match: has_double_sqrt
token: double n
result: double root
include: intr-func.l1h
include: math-const.l1h
include-post: math-lib.l1h
desc: "Calculate square root of a double"

code:
    (set const-int64 1 zero 0)
    (set const-double 1 pi 3.14159)
    (zero :math_init !)
    (n :math_sqrtdouble !)
    (root stpopd)
    (root :print_d !)
    (:print_n !)
