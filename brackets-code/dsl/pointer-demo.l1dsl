// pointer-demo.l1dsl
parser: "pointer demo"
include: intr-func.l1h
desc: "Pointer access demo"
code:
    (set const-int64 1 zero 0)
    (set const-int64 1 const100 100)
    (set int64 1 x 42)
    (set int64 1 Px 0)
    (set int64 1 val 0)
    // get pointer to x
    (x Px pointer)
    (Px [ zero ] val =)
    (val :print_i !)
    (:print_n !)
    // change value via pointer
    (const100 Px [ zero ] =)
    (x :print_i !)
    (:print_n !)
