// double-array-access.l1dsl
parser: "double array access, read double array, get double element, double array index"
match: has_double_array_access
token: double arr, int64 index
result: double value
include: intr-func.l1h
include: vars.l1h
desc: "Access a double array element by index"

code:
    (set int64 1 realind 0)
    (index * int64_size realind :=)
    (arr [ realind ] value =)
    (value +d zero value :=)
