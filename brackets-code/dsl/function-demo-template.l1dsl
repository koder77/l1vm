// function-demo-template.l1dsl
parser: "function, define function, subroutine"
include: intr-func.l1h
desc: "Function definition example"

code:
    (set const-int64 1 zero 0)
    (set int64 1 x 23)
    (set int64 1 y 42)
    (set int64 1 a 0)
    (set int64 1 sq 0)
    (set string s hello "Hello world!")
    (hello :print_s !)
    (:print_n !)
    (x * y a :=)
    (a :print_i !)
    (:print_n !)
    (y * y sq :=)
    (sq :print_i !)
    (:print_n !)
    (zero :exit !)
