// random-number.l1dsl
parser: "random number, zufallszahl, random"
match: has_random
include: intr-func.l1h
var: const-int64 zero 1 0
var: const-int64 one 1 1
var: const-int64 count 1 5
var: int64 i 1 0
var: int64 rnd 1 0
var: int64 f 1 0
desc: "Generate and print random numbers"

code:
    (zero i :=)
    (for-loop)
    (((i count <) f :=) f for)
        (hundred :random_i rnd !)
        (rnd :print_i !)
        (:print_n !)
        (i + one i :=)
    (next)
