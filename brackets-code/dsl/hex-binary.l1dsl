// hex-binary.l1dsl
parser: "hex binary"
include: intr-func.l1h
desc: "Hex and binary number demo"
code:
    (set const-int64 1 zero 0)
    (set byte 1 b &FF)
    (set int64 1 i &FFFFFFFFFFFFFFFF)
    (set byte 1 bbin B$10000001)
    (b :print_i !)
    (:print_n !)
    (i :print_i !)
    (:print_n !)
    (bbin :print_i !)
    (:print_n !)
