// array-access-int64.l1dsl
parser: "array access, read array, get element, array index"
match: has_array_access
token: int64 arr, int64 index
result: int64 value
include: intr-func.l1h
include: vars.l1h
desc: "Access an int64 array element by index"

code:
    (set int64 1 realind 0)
    (index * int64_size realind :=)
    (arr [ realind ] value =)
    (value + zero value :=)
