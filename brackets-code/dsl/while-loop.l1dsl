// while-loop.l1dsl
parser: "while loop"
include: intr-func.l1h
desc: "While loop example"
code:
    (set const-int64 1 zero 0)
    (set const-int64 1 one 1)
    (set int64 1 i 10)
    (set int64 1 f 0)
    (do)
        (i :print_i !)
        (:print_n !)
        (i - one i :=)
    (((i zero >) f :=) f while)
