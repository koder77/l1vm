// double-bmi.l1dsl
parser: "bmi double, body mass index double"
match: has_double_bmi
token: double weight, double height
result: double bmi
include: intr-func.l1h
var: const-double zero 1 0.0
desc: "Calculate Body Mass Index using double precision"

code:
    (height *d height h2 :=)
    (weight /d h2 bmi :=)
    (bmi :print_d !)
    (:print_n !)
