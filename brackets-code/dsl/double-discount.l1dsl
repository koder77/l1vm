// double-discount.l1dsl
parser: "discount double, price discount double"
match: has_double_discount
token: double price, double percent
result: double final_price
include: intr-func.l1h
desc: "Calculate discounted price using double precision"

code:
    (set const-double 1 onehundred 100.0)
    (set double 1 discount 0.0)
    ((price percent *d) discount =)
    ((discount onehundred /d) discount =)
    ((price discount -d) final_price =)
    (final_price :print_d !)
    (:print_n !)
