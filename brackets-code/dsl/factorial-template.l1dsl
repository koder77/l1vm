// factorial-template.l1dsl
parser: "factorial, iterative factorial"
include: intr-func.l1h
desc: "Calculate factorial of 5 with iteration"

code:
    (set const-int64 1 zero 0)
    (set const-int64 1 one 1)
    (set const-int64 1 n 5)
    (set int64 1 i 1)
    (set int64 1 fact 1)
    (set int64 1 f 0)
    (for-loop)
    (((i n <=) f :=) f for)
        (fact i * fact :=)
        (i + one i :=)
    (next)
    (fact :print_i !)
    (:print_n !)
    (zero :exit !)
