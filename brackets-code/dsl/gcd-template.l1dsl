// gcd-template.l1dsl
parser: "gcd, greatest common divisor"
include: intr-func.l1h
desc: "GCD (greatest common divisor) of 42 and 9"

code:
    (set const-int64 1 zero 0)
    (set int64 1 a 42)
    (set int64 1 b 9)
    (set int64 1 temp 0)
    (set int64 1 f 0)
    (do)
        (a % b temp :=)
        (b a :=)
        (temp b :=)
    (((b zero >) f :=) f while)
    (a :print_i !)
    (:print_n !)
    (zero :exit !)
