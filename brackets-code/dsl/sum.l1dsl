// sum.l1dsl
parser: "sum"
include: intr-func.l1h
desc: "Sum of numbers from 1 to N"
code:
    (set const-int64 1 zero 0)
    (set int64 1 one 1)
    (set int64 1 n 100)
    (set int64 1 sum 0)
    (set int64 1 i 0)
    (set int64 1 f 0)
    (zero i :=)
    (for-loop)
    (((i n <=) f :=) f for)
        (sum + i sum :=)
        (i + one i :=)
    (next)
    (sum :print_i !)
    (:print_n !)
