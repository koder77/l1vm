// struct-demo.l1dsl
parser: "struct demo"
include: intr-func.l1h
desc: "Person struct (dotted vars) demo"
code:
    (set const-int64 1 zero 0)
    (set const-string 64 person.name "Jane")
    (set const-string 64 person.city "New York")
    (set int64 1 person.age 30)
    (person.name :print_s !)
    (:print_n !)
    (person.city :print_s !)
    (:print_n !)
    (person.age :print_i !)
    (:print_n !)
